# Overpass droplet config. Copy to .env (setup.sh does this for you) and adjust if needed.

# The droplet's PRIVATE VPC IPv4 — Overpass binds to this interface only. setup.sh auto-detects it
# from the DigitalOcean metadata API; set it by hand only if that fails.
OVERPASS_BIND_IP=

# Keep the DB small (no OSM metadata). Set to "yes" only if you need attribution/timestamps.
OVERPASS_META=no

# Hungary extract + its hourly diff feed. Swap the country here to host a different region.
OVERPASS_PLANET_URL=https://download.geofabrik.de/europe/hungary-latest.osm.bz2
OVERPASS_DIFF_URL=https://download.geofabrik.de/europe/hungary-updates/
