APP_NAME="Hide & Seek"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://hide-and-seek.test

# URL of the Angular web client — used for CORS and generated links.
WEB_APP_URL=http://localhost:4321

# Comma-separated emails allowed into the Filament /admin panel. Leave empty and NO ONE can
# access /admin (every user is 403'd at the gate) — set at least one admin email.
FILAMENT_ADMIN_EMAILS=

# Hungarian-first: `hu` is the default UI locale, `en` the fallback.
APP_LOCALE=hu
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=hu_HU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Realtime uses Laravel Reverb (see REVERB_* below). Set to `log` only if you're running without
# a Reverb server — the app still works via /state polling, just not live.
BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# Reverb WebSocket server. REVERB_APP_KEY must match the web client's
# `environment.development.ts` → `reverb.key`. Use fresh, private values in production.
REVERB_APP_ID=hide-and-seek
REVERB_APP_KEY=4htb5glvhto3zeaif1is
REVERB_APP_SECRET=local-dev-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Geo question engine — OpenStreetMap features are read from Overpass.
OVERPASS_ENDPOINT=https://overpass-api.de/api/interpreter
OVERPASS_USER_AGENT="HideAndSeek/1.0 (+https://hide-and-seek.test)"

# Developer/debug API powering the web app's /dev cockpit. Keep GAME_DEBUG=false outside local
# dev; GAME_DEBUG_TOKEN must match the web client's `environment.development.ts` → `developerToken`.
GAME_DEBUG=false
GAME_DEBUG_TOKEN=local-dev-token

# Mail (password resets, notifications). `log` writes mails to the log; switch to smtp/ses/etc.
# in production and add the matching MAIL_HOST/PORT/USERNAME/PASSWORD keys.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@hide-and-seek.test"
MAIL_FROM_NAME="${APP_NAME}"

# Error monitoring (Sentry). Empty DSN = disabled. Keep PII off for GDPR.
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Admin "Deploy" button — runs deploy.sh from the panel. Off unless the server is set up for it.
ADMIN_DEPLOY_ENABLED=false
